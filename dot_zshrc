# Set personal aliases, overriding those provided by Oh My Zsh libs,
# plugins, and themes. Aliases can be placed here, though Oh My Zsh
# users are encouraged to define aliases within a top-level file in
# the $ZSH_CUSTOM folder, with .zsh extension. Examples:
# - $ZSH_CUSTOM/aliases.zsh
# - $ZSH_CUSTOM/macos.zsh
# For a full list of active aliases, run `alias`.
#
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"

# Force Shell
# export SHELL=/bin/bash

# Path setup — add your local installs first
export PATH="$HOME/.local/bin:$PATH"
# export PATH="$HOME/opt/tmux:$PATH"
# export PATH="$HOME/opt/python3.11/bin:$PATH"
# export PATH="$HOME/opt/neovim/bin:$PATH"
# export PATH="$HOME/opt/node/bin:$PATH"
# export PATH="$HOME/opt/lua/bin:$PATH"
# export PATH="$HOME/opt/luarocks/bin:$PATH"
# export PATH="$HOME/opt/fzf/bin:$PATH"
# export PATH="$HOME/opt/bat:$PATH"
# export PATH="$HOME/opt/zsh/bin:$PATH"  # local zsh bin if needed
# export PATH="$HOME/opt/gcc-arm/bin:$PATH"
# export PATH="$HOME/opt/llvm/bin:$PATH"
# export PATH="$HOME/opt/bear/bin:$PATH"
# export PATH="$HOME/opt/bear/bin:$PATH"
# export PATH=$HOME/opt/go/bin:$HOME/go/bin:$PATH

# export LD_LIBRARY_PATH="$HOME/opt/lib:$LD_LIBRARY_PATH"
# export LIBRARY_PATH="$HOME/opt/lib:$LIBRARY_PATH"
# export C_INCLUDE_PATH="$HOME/opt/include:$C_INCLUDE_PATH"

# Git config
export GIT_DISCOVERY_ACROSS_FILESYSTEM=1

# Use your local bat and fzf
export BAT_PAGER="less"
export BAT_STYLE="numbers"
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --border"

# Oh My Zsh settings
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="af-magic"  		# change to your favorite, e.g. agnoster, bira, ys
plugins=(git fzf z)       	# add plugins you like (fzf, git, z for directory jumping)

source $ZSH/oh-my-zsh.sh

# Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias grep='grep --color=auto'
alias bat='batcat'
alias cat='batcat' # --paging=never --style=plain'
alias ..='cd ..'
alias ...='cd ../..'
alias c='clear'

# Set/force nvim as default editor
alias vim="nvim"
alias vi="nvim"
alias oldvim="nvim"
alias vimdiff="nvim -d"
export EDITOR=nvim

# Alias programs
# alias STM32CubeProgrammer="$HOME/bin/STM32CubeProgrammer.sh"

# nobackup link
# ln -s /nobackup/rp258058 ~/nobackup

# Caps mapped to ctrl
setxkbmap -option 
setxkbmap -option ctrl:nocaps

# FZF Start from HOME by default
export FZF_DEFAULT_COMMAND="fdfind . $HOME"
# fzf keybindings and completions (Oh My Zsh fzf plugin loads them but re-adding to be sure)
[ -f ~/.fzf/shell/key-bindings.zsh ] && source ~/.fzf/shell/key-bindings.zsh
[ -f ~/.fzf/shell/completion.zsh ] && source ~/.fzf/shell/completion.zsh
# FZF options with bat preview
export FZF_CTRL_T_OPTS="--preview 'batcat --paging=never --color=always --style=numbers {}' --preview-window=right:60%"
export FZF_ALT_C_OPTS="--preview 'tree -C {} | head -200' --height=40%"

# History config
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt APPEND_HISTORY           # Append rather than overwrite history
setopt SHARE_HISTORY            # Share history across sessions
setopt HIST_IGNORE_DUPS         # Ignore duplicate commands
setopt HIST_FIND_NO_DUPS        # No duplicates in history search

# Enable syntax highlighting (if installed)
if [ -f ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]; then
  source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# Enable autosuggestions (if installed)
if [ -f ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]; then
  source ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# Optional: Clear screen on new session
[[ $- == *i* ]] && clear

# Auto-activate venv if it exists
if [ -f ./.venv/bin/activate ]; then
  source ./.venv/bin/activate
fi
